# =============================================================================
# .env.example — Inmobiliaria Inteligente 2.0 (Vacker)
# Copiá este archivo a .env y completá los valores. NUNCA commitees .env.
# En el Paso 1 (Fundaciones) solo se usan API_PORT y NEXT_PUBLIC_API_URL.
# El resto son placeholders para el Paso 2 (núcleo backend / Supabase).
# =============================================================================

# --- Backend / Supabase: PostgreSQL (Prisma) --------------------------------
# DATABASE_URL: conexión POOLED (pgbouncer, puerto 6543). La usa la app en runtime.
# DIRECT_URL:   conexión DIRECTA (puerto 5432). La usa Prisma para migraciones.
# Ambas salen del botón "Connect" del panel de Supabase (pestaña ORMs).
# Reemplazá [YOUR-PASSWORD] por la contraseña de la base.
DATABASE_URL=
DIRECT_URL=

# --- Backend / Supabase: Auth + Storage -------------------------------------
# SUPABASE_URL = https://<project-id>.supabase.co
SUPABASE_URL=
# anon / public key (se puede exponer al cliente)
SUPABASE_ANON_KEY=
# service_role / secret key: SECRETA, salta RLS. SOLO backend, nunca en el front.
SUPABASE_SERVICE_ROLE_KEY=

# --- API (apps/api) ----------------------------------------------------------
# Puerto del backend NestJS
API_PORT=3001

# --- Web (apps/web) ----------------------------------------------------------
# URL base de la API que consume el frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
