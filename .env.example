# =============================================================================
# .env.example — Inmobiliaria Inteligente 2.0 (Vacker)
# Copiá este archivo a .env y completá los valores. NUNCA commitees .env.
# En el Paso 1 (Fundaciones) solo se usan API_PORT y NEXT_PUBLIC_API_URL.
# El resto son placeholders para el Paso 2 (núcleo backend / Supabase).
# =============================================================================

# --- Backend / Supabase (Paso 2 en adelante) --------------------------------
# Cadena de conexión a PostgreSQL (Supabase). La aporta el humano (CLAUDE.md §10).
DATABASE_URL=
# Proyecto Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- API (apps/api) ----------------------------------------------------------
# Puerto del backend NestJS
API_PORT=3001

# --- Web (apps/web) ----------------------------------------------------------
# URL base de la API que consume el frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
