{
  "extends": "@vacker/config/tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,
    "jsx": "react-jsx",
    "outDir": "dist",
    "baseUrl": ".",
    "types": ["node", "vitest/globals"]
  },
  "include": ["src", "test"]
}
