{
  "name": "@vacker/api",
  "version": "0.0.0",
  "private": true,
  "prisma": {
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "dotenv -e ../../.env -- nest start --watch",
    "build": "nest build",
    "start": "dotenv -e ../../.env -- node dist/main.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "prisma:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "seed:test-user": "dotenv -e ../../.env -- tsx prisma/seed-test-user.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.4",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.4",
    "@nestjs/platform-express": "^11.0.4",
    "@nestjs/swagger": "^11.0.3",
    "@prisma/client": "^6.2.1",
    "@vacker/types": "workspace:*",
    "nestjs-cls": "^5.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.2",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.4",
    "@swc/core": "^1.10.7",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "pg": "^8.13.1",
    "@vacker/config": "workspace:*",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.18.0",
    "prisma": "^6.2.1",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "unplugin-swc": "^1.5.1",
    "vitest": "^3.0.2"
  }
}
